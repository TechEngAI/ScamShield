# ============================================================================
# ScamShield NG - Environment Variables Configuration
# 
# Copy this file to .env and fill in the actual values from your Supabase
# project. NEVER commit the actual .env file to version control.
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Your Supabase project URL
# Found in: Supabase Dashboard > Project Settings > API
# Format: https://[project-ref].supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (public, safe to expose in frontend)
# Found in: Supabase Dashboard > Project Settings > API > anon public key
# Used by frontend (React) and some backend operations
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (SECRET - backend only!)
# Found in: Supabase Dashboard > Project Settings > API > service_role secret
# NEVER expose this in frontend code
# Used for admin operations, user creation, RLS bypass
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# REACT (FRONTEND) SPECIFIC
# ============================================================================

# Note: React env vars must be prefixed with REACT_APP_
# These are publicly visible in the browser, so never put secrets here

# Supabase project URL (same as above, but prefixed for React)
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key (same as above, but prefixed for React)
# This is safe to expose as it's designed to be public
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend API URL (where your Express server is running)
# Development: http://localhost:3001
# Production: https://api.scamshield.ng
REACT_APP_API_URL=http://localhost:3001

# Optional: Enable debug logging in the frontend
# Set to 'true' for development, 'false' for production
REACT_APP_DEBUG=false

# ============================================================================
# NODE.JS (BACKEND) SPECIFIC
# ============================================================================

# Backend server port
NODE_PORT=3001

# Backend server environment
NODE_ENV=development

# Optional: CORS origins (comma-separated)
# Specifies which frontend URLs can call this backend
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# SUPABASE AUTH CONFIGURATION
# ============================================================================

# OTP Expiry time in seconds (default: 600 = 10 minutes)
# This should match your Supabase auth settings
OTP_EXPIRY_SECONDS=600

# Email validation settings
# Set to true if you want to verify email ownership (not required for OTP flow)
SUPABASE_EMAIL_VERIFICATION_ENABLED=false

# ============================================================================
# DATABASE & PERFORMANCE
# ============================================================================

# Optional: Database connection string (if using direct PostgreSQL)
# Format: postgresql://user:password@host:port/database
# If not set, operations will go through Supabase API
DATABASE_URL=postgresql://postgres:password@localhost:5432/scamshield

# Optional: Database connection pool size
DATABASE_POOL_SIZE=10

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================

# Rate limiting: Max OTP requests per email per window
# Recommended: 3-5 requests per 15 minutes
RATE_LIMIT_OTP_ATTEMPTS=5
RATE_LIMIT_OTP_WINDOW_MINUTES=15

# Optional: Redis URL for rate limiting cache
# If not set, will use in-memory store (not recommended for production)
# Format: redis://username:password@host:port/database
REDIS_URL=redis://localhost:6379/0

# Optional: JWT secret (for additional token validation if needed)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================================
# AI/ML INTEGRATION (Future)
# ============================================================================

# OpenAI API key (if using ChatGPT for fraud detection explanations)
OPENAI_API_KEY=sk-...

# Cohere API key (alternative to OpenAI)
COHERE_API_KEY=...

# ============================================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=https://key@sentry.io/project

# Optional: Google Analytics tracking ID
GOOGLE_ANALYTICS_ID=

# Optional: Segment write key
SEGMENT_WRITE_KEY=

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================

# If you want to send custom emails, not just Supabase OTP emails
# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# From email address
EMAIL_FROM=noreply@scamshield.ng
EMAIL_FROM_NAME=ScamShield NG

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Twilio (for SMS if you want SMS OTP in future)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# SUPABASE EDGE FUNCTIONS (Optional)
# ============================================================================

# These are configured in supabase/config.toml
# But you may need them here for testing

# Edge function endpoint
EDGE_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1

# ============================================================================
# NOTES
# ============================================================================

# To get Supabase credentials:
# 1. Go to https://supabase.com
# 2. Create a new project
# 3. Go to Project Settings > API
# 4. Copy the Project URL and anon/service-role keys
#
# For development:
# - Copy this file to .env (or .env.local for React)
# - Never commit real .env file to git
# - Add .env to .gitignore
#
# For production:
# - Set these as environment variables in your hosting platform
# - (Vercel, Railway, Heroku, etc.)
# - Use secrets management for sensitive values
