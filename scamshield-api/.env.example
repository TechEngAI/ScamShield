# ScamShield API environment variables

# Port for the Express server to listen on
PORT=3001

# Node environment: development or production
NODE_ENV=development

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public key for client-side operations
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key for server-side operations and RLS bypass
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redirect URL used by Supabase email sign-in
EMAIL_REDIRECT_TO=http://localhost:3000/auth/callback

# Anthropic API key for future AI fraud detection integration
ANTHROPIC_API_KEY=claude-api-key

# Groq API key for the scam classifier engine
GROQ_API_KEY=your_groq_api_key_here

# API token used for simple protected endpoints (replace in production)
API_TOKEN=changeme

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Twilio WhatsApp Integration
# Found in: Twilio Console > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Your Twilio WhatsApp sandbox number (include country code, no whatsapp: prefix)
TWILIO_WHATSAPP_NUMBER=+14155238886
# Your public webhook URL (use ngrok for local development)
TWILIO_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/api/whatsapp/webhook
